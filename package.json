{
  "name": "nestjs-ai",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS AI Monorepo",
  "keywords": [
    "ai",
    "monorepo",
    "nestjs"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "turbo run test",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "docs:build": "pnpm exec antora --fetch --stacktrace --to-dir ./site ./docs/antora/antora-playbook.yml",
    "docs:clean": "rimraf docs/antora/site",
    "clean": "turbo run clean --force && rimraf .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antora/atlas-extension": "^1.0.0-alpha.5",
    "@antora/cli": "3.1.14",
    "@antora/collector-extension": "1.0.2",
    "@antora/site-generator": "3.1.14",
    "@asciidoctor/tabs": "^1.0.0-beta.6",
    "@changesets/cli": "^2.30.0",
    "@djencks/asciidoctor-mathjax": "^0.0.9",
    "@springio/antora-extensions": "^1.14.2",
    "@springio/asciidoctor-extensions": "^1.0.0-alpha.12",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.9",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*": "oxfmt --write --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs}": "oxlint --fix"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
