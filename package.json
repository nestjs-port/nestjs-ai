{
	"name": "nestjs-ai",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "NestJS AI Monorepo",
	"scripts": {
		"build": "pnpm -r build",
		"dev": "pnpm -r --parallel dev",
		"lint": "biome check .",
