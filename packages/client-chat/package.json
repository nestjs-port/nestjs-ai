{
  "name": "@nestjs-ai/client-chat",
  "version": "0.0.2",
  "private": false,
  "description": "Chat client support for NestJS AI",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/client-chat"
  },
  "keywords": [
    "nestjs",
    "ai",
    "client",
    "chat"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*",
    "@nestjs-ai/model": "*",
    "@nestjs-ai/template-st": "*",
    "@nestjs-port/core": "^0.0.3",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-ai/template-st": "workspace:*",
    "@nestjs-ai/testing": "workspace:*",
    "@nestjs-port/core": "^0.0.3",
    "@nestjs/common": "^11.1.11",
    "rxjs": "^7.0.0",
    "zod": "4.3.6"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
