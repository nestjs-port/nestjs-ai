{
  "name": "@nestjs-ai/session",
  "version": "0.0.1",
  "private": false,
  "description": "Structured, event-sourced session management with context compaction for NestJS AI",
  "keywords": [
    "ai",
    "compaction",
    "memory",
    "nestjs",
    "session"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "bugs": {
    "url": "https://github.com/nestjs-port/nestjs-ai/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/community/session/session"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "prepack": "shx cp ../../../../README.md README.md"
  },
  "devDependencies": {
    "@nestjs-ai/client-chat": "workspace:*",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-port/core": "^0.1.1",
    "@nestjs/common": "^11.1.11",
    "@nestjs/testing": "^11.1.11",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@nestjs-ai/client-chat": "^0.1.3",
    "@nestjs-ai/commons": "^0.1.2",
    "@nestjs-ai/model": "^0.1.5",
    "@nestjs-port/core": "^0.1.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.12 || ^0.2.0",
    "rxjs": "^7.8.2",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
