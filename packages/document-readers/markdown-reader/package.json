{
  "name": "@nestjs-ai/document-reader-markdown",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": false,
  "description": "Markdown document reader for NestJS AI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@types/commonmark": "^0.27.10"
  },
  "dependencies": {
    "commonmark": "^0.31.2",
    "fast-glob": "^3.3.3"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
