{
  "name": "@nestjs-ai/document-reader-markdown",
  "version": "0.1.1",
  "private": false,
  "description": "Markdown document reader for NestJS AI",
  "keywords": [
    "ai",
    "document",
    "markdown",
    "nestjs",
    "reader"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/document-readers/markdown-reader"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "commonmark": "^0.31.2",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@types/commonmark": "^0.27.10"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "^0.1.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
