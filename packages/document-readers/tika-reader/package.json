{
  "name": "@nestjs-ai/document-reader-tika",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": false,
  "description": "Tika-based document reader for NestJS AI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "testcontainers": "^11.13.0"
  }
}
