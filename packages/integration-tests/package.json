{
  "name": "@nestjs-ai/integration-tests",
  "version": "0.0.0",
  "private": true,
  "description": "Integration tests for NestJS AI",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/integration-tests"
  },
  "keywords": [
    "nestjs",
    "ai",
    "integration",
    "tests"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "postinstall": "pnpm prisma:generate",
    "prisma:generate": "DATABASE_URL=postgresql://jsdbc:jsdbc@localhost:5432/jsdbc_integration pnpm exec prisma generate --schema __tests__/jsdbc/prisma/schema.prisma",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "node -e \"const fs=require('fs');const path=require('path');let dir=process.cwd();let root=null;while(true){const pkg=path.join(dir,'package.json');if(fs.existsSync(pkg)){try{const json=JSON.parse(fs.readFileSync(pkg,'utf8'));if(json.name==='nestjs-ai'){root=dir;break;}}catch{} }const parent=path.dirname(dir);if(parent===dir) throw new Error('Unable to locate NestJS AI repo root');dir=parent;}fs.copyFileSync(path.join(root,'README.md'),path.join(process.cwd(),'README.md'));\"",
    "postpack": "node -e \"const fs=require('fs');const path=require('path');const file=path.join(process.cwd(),'README.md');if(fs.existsSync(file)) fs.unlinkSync(file);\""
  },
  "devDependencies": {
    "@google/genai": "^1.49.0",
    "@mikro-orm/core": "^7.0.10",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.10",
    "@nestjs-ai/client-chat": "workspace:*",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/jsdbc": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-ai/model-chat-memory-repository-jsdbc": "workspace:*",
    "@nestjs-ai/model-chat-memory-repository-redis": "workspace:*",
    "@nestjs-ai/model-google-genai": "workspace:*",
    "@nestjs-ai/model-openai": "workspace:*",
    "@nestjs-ai/model-openai-sdk": "workspace:*",
    "@nestjs-ai/model-transformers": "workspace:*",
    "@nestjs-ai/observation": "workspace:*",
    "@nestjs-ai/platform": "workspace:*",
    "@nestjs-ai/vector-store": "workspace:*",
    "@nestjs-ai/vector-store-redis": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/testing": "^11.1.11",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@prisma/client": "^6.18.0",
    "@testcontainers/mysql": "^11.13.0",
    "@testcontainers/mariadb": "^11.13.0",
    "@testcontainers/mssqlserver": "^11.13.0",
    "@testcontainers/oraclefree": "^11.13.0",
    "@testcontainers/postgresql": "^11.13.0",
    "oracledb": "^6.9.0",
    "mssql": "^11.0.1",
    "pg": "^8.20.0",
    "prisma": "^6.18.0",
    "sql.js": "^1.13.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.7",
    "testcontainers": "^11.13.0",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  }
}
