{
  "name": "@nestjs-ai/jsdbc",
  "version": "0.0.2",
  "private": false,
  "description": "JDBC integration",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/jsdbc"
  },
  "keywords": [
    "nestjs",
    "ai",
    "jsdbc"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./typeorm": {
      "types": "./dist/typeorm/index.d.ts",
      "require": "./dist/typeorm/index.js"
    },
    "./mikroorm": {
      "types": "./dist/mikroorm/index.d.ts",
      "require": "./dist/mikroorm/index.js"
    },
    "./sequelize": {
      "types": "./dist/sequelize/index.d.ts",
      "require": "./dist/sequelize/index.js"
    },
    "./prisma": {
      "types": "./dist/prisma/index.d.ts",
      "require": "./dist/prisma/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "prepack": "node -e \"const fs=require('fs');const path=require('path');let dir=process.cwd();let root=null;while(true){const pkg=path.join(dir,'package.json');if(fs.existsSync(pkg)){try{const json=JSON.parse(fs.readFileSync(pkg,'utf8'));if(json.name==='nestjs-ai'){root=dir;break;}}catch{} }const parent=path.dirname(dir);if(parent===dir) throw new Error('Unable to locate NestJS AI repo root');dir=parent;}fs.copyFileSync(path.join(root,'README.md'),path.join(process.cwd(),'README.md'));\"",
    "postpack": "node -e \"const fs=require('fs');const path=require('path');const file=path.join(process.cwd(),'README.md');if(fs.existsSync(file)) fs.unlinkSync(file);\""
  },
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.0",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "@prisma/client": "^6.18.0",
    "class-transformer": "^0.4.0 || ^0.5.0",
    "sequelize": "^6.37.0",
    "typeorm": "^0.3.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/sequelize": {
      "optional": true
    },
    "@mikro-orm/core": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "sequelize": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mikro-orm/core": "^7.0.10",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/typeorm": "^11.0.1",
    "@prisma/client": "^6.18.0",
    "class-transformer": "^0.5.1",
    "sequelize": "^6.37.7",
    "typeorm": "^0.3.28",
    "zod": "4.3.6"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
