  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0"
  }
