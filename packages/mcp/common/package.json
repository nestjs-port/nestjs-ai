{
  "name": "@nestjs-ai/mcp-common",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": false,
  "description": "Shared MCP primitives for NestJS AI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
