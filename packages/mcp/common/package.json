{
  "name": "@nestjs-ai/mcp-common",
  "version": "0.0.2",
  "private": false,
  "description": "Shared MCP primitives for NestJS AI",
  "keywords": [
    "ai",
    "common",
    "mcp",
    "nestjs"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/mcp/common"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-port/core": "^0.0.3"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "workspace:^",
    "@nestjs-ai/model": "workspace:^",
    "@nestjs-port/core": "^0.0.3"
  }
}
