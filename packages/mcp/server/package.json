{
  "name": "@nestjs-ai/mcp-server",
  "version": "0.1.2",
  "private": false,
  "description": "MCP server support for NestJS AI",
  "keywords": [
    "ai",
    "mcp",
    "nestjs",
    "server"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/mcp/server"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./transport/streamable-http": {
      "types": "./dist/transport/streamable-http/index.d.ts",
      "default": "./dist/transport/streamable-http/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/mcp-annotations": "workspace:*",
    "@nestjs-ai/mcp-common": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-port/core": "^0.1.1",
    "@nestjs/common": "^11.1.11",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/platform-fastify": "^11.1.11",
    "@nestjs/testing": "^11.1.11",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@nestjs-ai/commons": "^0.1.1",
    "@nestjs-ai/mcp-annotations": "^0.1.2",
    "@nestjs-ai/mcp-common": "^0.1.3",
    "@nestjs-ai/model": "^0.1.2",
    "@nestjs-port/core": "^0.1.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.12 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/node": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
