{
  "name": "@nestjs-ai/model-chat-memory-repository-redis",
  "version": "0.0.0",
  "description": "Redis-backed Chat Memory Repository for NestJS AI",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*",
    "@nestjs-ai/model": "*"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "testcontainers": "^11.12.0"
  },
  "dependencies": {
    "@redis/json": "^5.11.0",
    "@redis/search": "^5.11.0",
    "redis": "^5.11.0"
  }
}
