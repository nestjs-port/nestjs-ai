    "test": "vitest run"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*",
    "@nestjs-ai/model": "*",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "redis": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "@testcontainers/redis": "^11.13.0",
    "redis": "^5.11.0",
    "testcontainers": "^11.13.0"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
