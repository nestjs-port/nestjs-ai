{
  "name": "@nestjs-ai/model",
  "version": "0.1.0",
  "private": false,
  "description": "Core model abstractions and tool support for NestJS AI",
  "keywords": [
    "ai",
    "model",
    "nestjs"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/model"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
