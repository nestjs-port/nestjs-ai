    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/template-st": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.0.0",
