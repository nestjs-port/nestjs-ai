{
  "name": "@nestjs-ai/model",
  "version": "0.0.2",
  "private": false,
  "description": "Core model abstractions and tool support for NestJS AI",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
