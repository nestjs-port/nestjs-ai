{
  "name": "@nestjs-ai/observation",
  "version": "0.0.1",
  "private": false,
  "description": "OpenTelemetry observation support for NestJS AI",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/observation"
  },
  "keywords": [
    "nestjs",
    "ai",
    "observation"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*",
    "@nestjs-ai/model": "*",
    "@nestjs/common": "^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs/common": "^11.1.11"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
