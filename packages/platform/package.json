    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-ai/template-st": "workspace:*",
    "@nestjs-port/core": "^0.1.1",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "^0.1.0",
    "@nestjs-ai/model": "^0.1.0",
    "@nestjs-ai/template-st": "^0.1.0",
    "@nestjs-port/core": "^0.1.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs-ai/template-st": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
