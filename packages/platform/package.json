{
  "name": "@nestjs-ai/platform",
  "version": "0.1.0",
  "private": false,
  "description": "NestJS platform integration for NestJS AI",
  "keywords": [
    "ai",
    "nestjs",
    "platform"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/platform"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
