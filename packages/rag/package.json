{
  "name": "@nestjs-ai/rag",
  "version": "0.1.1",
  "private": false,
  "description": "Retrieval Augmented Generation (RAG) support for NestJS AI",
  "keywords": [
    "ai",
    "nestjs",
    "rag"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/rag"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@nestjs-ai/client-chat": "workspace:*",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-ai/vector-store": "workspace:*",
    "@nestjs-port/core": "^0.1.1"
  },
  "peerDependencies": {
    "@nestjs-ai/client-chat": "^0.1.1",
    "@nestjs-ai/commons": "^0.1.1",
    "@nestjs-ai/model": "^0.1.1",
    "@nestjs-ai/vector-store": "^0.1.2",
    "@nestjs-port/core": "^0.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
