{
  "name": "@nestjs-ai/rag",
  "version": "0.0.2",
  "private": false,
  "description": "Retrieval Augmented Generation (RAG) support for NestJS AI",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/rag"
  },
  "keywords": [
    "nestjs",
    "ai",
    "rag"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@nestjs-ai/client-chat": "*",
    "@nestjs-ai/commons": "*",
    "@nestjs-ai/model": "*",
    "@nestjs-ai/vector-store": "*"
  },
  "devDependencies": {
    "@nestjs-ai/client-chat": "workspace:*",
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-ai/vector-store": "workspace:*"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
