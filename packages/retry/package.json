{
  "name": "@nestjs-ai/retry",
  "version": "0.0.0",
  "description": "Retry utilities for NestJS AI - provides transient/non-transient exceptions and retry configuration",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "vitest": "^3.0.0"
  }
}
