{
  "name": "@nestjs-ai/retry",
  "version": "0.0.2",
  "private": false,
  "description": "Retry utilities for NestJS AI - provides transient/non-transient exceptions and retry configuration",
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/retry"
  },
  "keywords": [
    "nestjs",
    "ai",
    "retry"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "*"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
