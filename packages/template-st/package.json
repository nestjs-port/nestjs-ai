{
  "name": "@nestjs-ai/template-st",
  "version": "1.0.0",
  "private": false,
  "description": "StringTemplate renderer for NestJS AI",
  "keywords": [
    "ai",
    "nestjs",
    "st",
    "template"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/template-st"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "stringtemplate4ts": "^2.0.1"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-port/core": "^0.0.4"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "workspace:^",
    "@nestjs-port/core": "^0.0.4"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
