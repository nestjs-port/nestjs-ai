{
	"name": "@nestjs-ai/testing",
	"version": "0.0.0",
	"private": true,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm clean && tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@nestjs-ai/commons": "*"
	},
	"devDependencies": {
		"@nestjs-ai/commons": "workspace:*",
		"vitest": "^4.0.0"
	}
}
