{
  "name": "@nestjs-ai/vector-store",
  "version": "0.1.1",
  "private": false,
  "description": "Vector Store support for NestJS AI",
  "keywords": [
    "ai",
    "nestjs",
    "store",
    "vector"
  ],
  "homepage": "https://nestjs-port.github.io/nestjs-ai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs-port/nestjs-ai",
    "directory": "packages/vector-store"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "generate:antlr": "pnpm dlx antlr-ng -l -v -Dlanguage=TypeScript -o src/filter/antlr4 src/filter/antlr4/Filters.g4"
  },
  "dependencies": {
    "antlr4ng": "^3.0.16"
  },
  "devDependencies": {
    "@nestjs-ai/commons": "workspace:*",
    "@nestjs-ai/model": "workspace:*",
    "@nestjs-port/core": "^0.1.1",
    "@nestjs-port/testing": "^0.1.0"
  },
  "peerDependencies": {
    "@nestjs-ai/commons": "^0.1.0",
    "@nestjs-ai/model": "^0.1.0",
    "@nestjs-port/core": "^0.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
