    "@nestjs-ai/vector-store": "workspace:*",
    "@nestjs-port/core": "^0.0.4",
    "@nestjs-port/jsdbc": "^0.0.4",
    "@nestjs-port/testing": "^0.0.3",
    "@nestjs/common": "^11.1.11",
    "@testcontainers/postgresql": "^11.13.0",
    "pgvector": "^0.2.1",
